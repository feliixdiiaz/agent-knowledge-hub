#!/bin/bash
# hub - agent-knowledge-hub sub-hub CLI. Commands: create <name>, list.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
HUBS="$ROOT/hubs"; TPL="$ROOT/template"

count_notes() {
  find "$1" -maxdepth 1 -name '*.md' \
    ! -name INDEX.md ! -name AGENTS.md ! -name CLAUDE.md ! -name README.md ! -name log.md \
    | wc -l | tr -d ' '
}

cmd="${1:-}"
case "$cmd" in
  list)
    for d in "$HUBS"/*/; do
      [ -d "$d" ] || continue
      echo "$(basename "$d") ($(count_notes "$d") notes)"
    done
    ;;
  create)
    name="${2:-}"; [ -n "$name" ] || { echo "usage: hub create <name>"; exit 2; }
    dest="$HUBS/$name"
    [ -e "$dest" ] && { echo "hub '$name' exists"; exit 1; }
    mkdir -p "$dest"
    sed -e "s/{{HUB_NAME}}/$name/g" \
        -e "s/{{DOMAIN}}/REPLACE THIS LINE: one sentence on what findings this hub claims, plus tie-breakers vs your other sub-hubs./g" \
        "$TPL/AGENTS.md" > "$dest/AGENTS.md"
    sed "s/{{HUB_NAME}}/$name/g" "$TPL/INDEX.md" > "$dest/INDEX.md"
    printf '@AGENTS.md\n' > "$dest/CLAUDE.md"
    printf '# %s log\n\nAppend-only operations log. Format: `- <date> | <op> | <note> | <what+why>`. Newest at bottom.\n' "$name" > "$dest/log.md"
    echo "created hub: hubs/$name"
    echo "next: 1) edit hubs/$name/AGENTS.md scope line  2) add the hub to the root INDEX.md"
    ;;
  *)
    echo "hub <create <name> | list>"; exit 2 ;;
esac
